<UserControl x:Class="XDonation.Controls.DateInputBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="34" d:DesignWidth="160"
             Focusable="False"
             IsTabStop="False">

    <UserControl.Resources>
        <!-- ── Color Palette ── -->
        <Color x:Key="AccentColor">#1D6CB5</Color>
        <Color x:Key="AccentLightColor">#EBF5FF</Color>
        <Color x:Key="BorderColor">#CBD5E1</Color>
        <Color x:Key="BorderHoverColor">#94A3B8</Color>
        <Color x:Key="SeparatorColor">#C8D1DC</Color>
        <Color x:Key="PlaceholderColor">#A0AEC0</Color>
        <Color x:Key="TextColor">#1E293B</Color>
        <Color x:Key="SegmentHoverBg">#F1F5F9</Color>
        <Color x:Key="SegmentActiveBg">#EBF5FF</Color>
        <Color x:Key="ErrorColor">#EF4444</Color>

        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
        <SolidColorBrush x:Key="FieldBorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColor}"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}"/>
        <SolidColorBrush x:Key="PlaceholderBrush" Color="{StaticResource PlaceholderColor}"/>
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
        <SolidColorBrush x:Key="SegmentHoverBrush" Color="{StaticResource SegmentHoverBg}"/>
        <SolidColorBrush x:Key="SegmentActiveBrush" Color="{StaticResource SegmentActiveBg}"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>

        <!-- ── Segment TextBox Style ── -->
        <Style x:Key="SegmentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <!-- Pill highlight behind text -->
                            <Border x:Name="SegmentBg"
                                    Background="Transparent"
                                    CornerRadius="3"
                                    Margin="-1,-1,-1,-1"
                                    SnapsToDevicePixels="True"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                            <!-- Placeholder -->
                            <TextBlock x:Name="Placeholder"
                                       Text="{TemplateBinding Tag}"
                                       Foreground="{StaticResource PlaceholderBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="Normal"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Show placeholder when empty and not focused -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                            <!-- Hover: subtle bg -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SegmentBg" Property="Background" Value="{StaticResource SegmentHoverBrush}"/>
                            </Trigger>
                            <!-- Focused: accent bg -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="SegmentBg" Property="Background" Value="{StaticResource SegmentActiveBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Separator Style ── -->
        <Style x:Key="SeparatorStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="/"/>
            <Setter Property="Foreground" Value="{StaticResource SeparatorBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <!-- ── Root Border Style matching standard textboxes ── -->
        <Style x:Key="RootBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="4,1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- ── Root Container ── -->
    <Border x:Name="RootBorder"
            Style="{StaticResource RootBorderStyle}"
            MinWidth="160"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True"
            Cursor="IBeam"
            MouseDown="RootBorder_MouseDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="0" Opacity="0" ShadowDepth="0" Direction="270"/>
        </Border.Effect>

        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Calendar icon -->
                <ColumnDefinition Width="30"/>    <!-- Day -->
                <ColumnDefinition Width="Auto"/>  <!-- / -->
                <ColumnDefinition Width="30"/>    <!-- Month -->
                <ColumnDefinition Width="Auto"/>  <!-- / -->
                <ColumnDefinition Width="50"/>    <!-- Year -->
            </Grid.ColumnDefinitions>

            <!-- Calendar icon -->
            <Viewbox Grid.Column="0" Width="14" Height="14" Margin="2,0,4,0"
                     VerticalAlignment="Center" IsHitTestVisible="False"
                     Opacity="0.4">
                <Canvas Width="24" Height="24">
                    <Path Data="M19,4H18V2H16V4H8V2H6V4H5C3.89,4 3,4.9 3,6V20C3,21.1 3.9,22 5,22H19C20.1,22 21,21.1 21,20V6C21,4.9 20.1,4 19,4ZM19,20H5V10H19V20ZM19,8H5V6H19V8Z"
                          Fill="#64748B"/>
                </Canvas>
            </Viewbox>

            <!-- Day -->
            <TextBox x:Name="DayBox"
                     Grid.Column="1"
                     Style="{StaticResource SegmentTextBoxStyle}"
                     MaxLength="2"
                     Tag="JJ"
                     PreviewTextInput="DayBox_PreviewTextInput"
                     PreviewKeyDown="Segment_PreviewKeyDown"
                     TextChanged="DayBox_TextChanged"
                     GotFocus="Segment_GotFocus"
                     LostFocus="Segment_LostFocus"
                     PreviewMouseDown="Segment_PreviewMouseDown"/>

            <!-- Separator 1 -->
            <TextBlock Grid.Column="2" Style="{StaticResource SeparatorStyle}"/>

            <!-- Month -->
            <TextBox x:Name="MonthBox"
                     Grid.Column="3"
                     Style="{StaticResource SegmentTextBoxStyle}"
                     MaxLength="2"
                     Tag="MM"
                     PreviewTextInput="MonthBox_PreviewTextInput"
                     PreviewKeyDown="Segment_PreviewKeyDown"
                     TextChanged="MonthBox_TextChanged"
                     GotFocus="Segment_GotFocus"
                     LostFocus="Segment_LostFocus"
                     PreviewMouseDown="Segment_PreviewMouseDown"/>

            <!-- Separator 2 -->
            <TextBlock Grid.Column="4" Style="{StaticResource SeparatorStyle}"/>

            <!-- Year -->
            <TextBox x:Name="YearBox"
                     Grid.Column="5"
                     Style="{StaticResource SegmentTextBoxStyle}"
                     MaxLength="4"
                     Tag="AAAA"
                     PreviewTextInput="YearBox_PreviewTextInput"
                     PreviewKeyDown="Segment_PreviewKeyDown"
                     TextChanged="YearBox_TextChanged"
                     GotFocus="Segment_GotFocus"
                     LostFocus="Segment_LostFocus"
                     PreviewMouseDown="Segment_PreviewMouseDown"/>
        </Grid>
    </Border>
</UserControl>
