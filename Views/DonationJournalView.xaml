<UserControl x:Class="XpertPharm5Donation.Views.DonationJournalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:XpertPharm5Donation.Converters"
             Background="{StaticResource WorkspaceBrush}">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
        <conv:NotNullToVisibilityConverter x:Key="NotNullVis"/>
        <conv:ErrorToColorConverter x:Key="ErrorToColorConverter"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Filters & KPIs -->
            <RowDefinition Height="*"/>    <!-- Journal Grid -->
            <RowDefinition Height="Auto"/> <!-- Splitter -->
            <RowDefinition Height="2*"/>   <!-- Detail Grid -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══ TOP: FILTERS & KPI ════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" MinHeight="40">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Date Début :" FontSize="11" Foreground="#444" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding FilterDateFrom}" Width="120" MinHeight="28" BorderBrush="#DDD">
                                <DatePicker.Resources>
                                    <Style TargetType="DatePickerTextBox">
                                        <Setter Property="Text" Value="DD/MM/YYYY"/>
                                    </Style>
                                </DatePicker.Resources>
                            </DatePicker>
                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Date Fin :" FontSize="11" Foreground="#444" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding FilterDateTo}" Width="120" MinHeight="28" BorderBrush="#DDD"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Donneur :" FontSize="11" Foreground="#444" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FilterDonor, UpdateSourceTrigger=PropertyChanged}" Width="150" MinHeight="28" VerticalContentAlignment="Center" BorderBrush="#DDD"/>
                        </StackPanel>

                        <Button Command="{Binding LoadCommand}" MinWidth="90" MinHeight="30" Margin="0,15,8,0"
                                Style="{StaticResource PrimaryButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="🔍" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Filtrer" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Content="Réinitialiser" Command="{Binding ResetFiltersCommand}"
                                MinWidth="80" MinHeight="28" Margin="0,15,0,0" Style="{StaticResource GhostButtonStyle}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- KPI CARDS -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Border Background="White" BorderBrush="#E0E7FF" BorderThickness="1" CornerRadius="8" MinWidth="90" Margin="0,0,10,0" Padding="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Total Bons" FontSize="11" Foreground="#0066CC" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalVouchers}" FontSize="20" FontWeight="Bold" Foreground="#0066CC" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF7ED" BorderBrush="#FFEDD5" BorderThickness="1" CornerRadius="8" MinWidth="90" Padding="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Unités reçues" FontSize="11" Foreground="#9A3412" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalUnitsReceived}" FontSize="20" FontWeight="Bold" Foreground="#9A3412" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MIDDLE: JOURNAL GRID ════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Style="{StaticResource SectionHeaderBorderStyle}">
                    <TextBlock Text="Journal des Bons de Don" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Vouchers}" SelectedItem="{Binding SelectedVoucher}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          HeadersVisibility="Column" SelectionMode="Single"
                          RowHeight="32" BorderThickness="0" Background="Transparent"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" 
                                      Command="{Binding EditVoucherCommand}" 
                                      CommandParameter="{Binding SelectedVoucher}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N° Bon" Binding="{Binding VoucherNumber}" Width="120"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding DonorType}" Width="100"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding ReceiptDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Donneur" Binding="{Binding DonorName}" Width="2*"/>
                        <DataGridTextColumn Header="Nb Lignes" Binding="{Binding Lines.Count}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Unités reçues" Binding="{Binding TotalUnits}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="3*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ═══ SPLITTER ═══════════════════════════════════════════════════ -->
        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Background="#F1F5F9" VerticalAlignment="Center" Margin="0,4"/>

        <!-- ═══ BOTTOM: DETAIL GRID ════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="White" CornerRadius="6" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource SectionHeaderBorderStyle}">
                    <Grid>
                        <TextBlock Text="Détail — Lignes du bon de don" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="Sélectionnez un bon ▲" Foreground="#CBD5E1" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- DataGrid Detail (Visible only when a voucher is selected) -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedVoucher.Lines}"
                          Visibility="{Binding SelectedVoucher, Converter={StaticResource NotNullVis}}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          HeadersVisibility="Column" SelectionMode="Single"
                          RowHeight="30" BorderThickness="0" Background="Transparent"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Médicament" Binding="{Binding DrugName}" Width="3*"/>
                        <DataGridTextColumn Header="DCI" Binding="{Binding Dci}" Width="2*"/>
                        <DataGridTextColumn Header="Lot" Binding="{Binding BatchNumber}" Width="120"/>
                        <DataGridTextColumn Header="Expiration" Binding="{Binding ExpirationDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Quantité" Binding="{Binding Quantity}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Placeholder when no voucher is selected -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding SelectedVoucher, Converter={StaticResource NullVis}}">
                    <TextBlock Text="⚠ Sélectionnez un bon de don dans la liste ci-dessus pour voir ses lignes." 
                               Foreground="#64748B" FontSize="14" FontFamily="Segoe UI"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ FOOTER: STATUS & BUTTONS ══════════════════════════════════ -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" HorizontalAlignment="Left"
                       Foreground="#15803D" FontSize="13" FontWeight="SemiBold"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding NewVoucherCommand}" Width="110" Height="32" Margin="0,0,8,0"
                        Style="{StaticResource SuccessButtonStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⊕" FontSize="16" Margin="0,-2,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nouveau" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding EditVoucherCommand}" Width="110" Height="32" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="✏" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Modifier" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding DeleteVoucherCommand}" Width="110" Height="32" Margin="0,0,8,0"
                        Style="{StaticResource DangerButtonStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🗑" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Supprimer" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding LoadCommand}" Width="110" Height="32" Margin="0,0,8,0"
                        Style="{StaticResource GhostButtonStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⟳" FontSize="16" Margin="0,-2,6,0" VerticalAlignment="Center" Foreground="#334155"/>
                        <TextBlock Text="Actualiser" FontSize="12" VerticalAlignment="Center" Foreground="#334155"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding PrintVoucherCommand}" Width="110" Height="32"
                        Style="{StaticResource GhostButtonStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⎙" FontSize="16" Margin="0,-2,6,0" VerticalAlignment="Center" Foreground="#334155"/>
                        <TextBlock Text="Imprimer" FontSize="12" VerticalAlignment="Center" Foreground="#334155"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
