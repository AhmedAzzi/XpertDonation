<UserControl x:Class="XpertPharm5Donation.Views.DonationJournalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080"
             Background="{StaticResource WorkspaceBrush}">

    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding LoadCommand}"/>
    </UserControl.InputBindings>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ FILTRES ET STATS ════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect Color="#111" BlurRadius="10" Opacity="0.05" Direction="270" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Dates -->
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="Du" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding FilterDateFrom}" Width="120" Style="{StaticResource ModernDatePickerStyle}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="Au" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding FilterDateTo}" Width="120" Style="{StaticResource ModernDatePickerStyle}"/>
                    </StackPanel>

                    <!-- Statut -->
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="Statut" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <ComboBox SelectedValue="{Binding FilterStatus}" SelectedValuePath="Content" Width="120" Style="{StaticResource ModernComboBoxStyle}">
                            <ComboBoxItem Content="Tous"/>
                            <ComboBoxItem Content="Validé"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Donneur -->
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="Donneur" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FilterDonor, UpdateSourceTrigger=PropertyChanged}" Width="150" Style="{StaticResource FlatTextBoxStyle}"/>
                    </StackPanel>

                    <!-- Boutons Actions -->
                    <Button Content="🔍 Filtrer" Command="{Binding LoadCommand}" Style="{StaticResource ActionButtonStyle}"
                            Background="{StaticResource PrimaryDarkBrush}" Height="34" Margin="0,18,8,0" Padding="16,0"/>
                    
                    <Button Content="Réinitialiser" Command="{Binding ResetFiltersCommand}"
                            Background="Transparent" BorderThickness="0" Foreground="#666" Margin="0,18,0,0" ToolTip="Effacer les filtres"/>
                </StackPanel>

                <!-- Stats summary -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Background="#E8F5E9" CornerRadius="4" Padding="12,6" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Validés" FontSize="10" Foreground="#2E7D32"/>
                            <TextBlock Text="{Binding TotalValidated}" FontSize="16" FontFamily="Segoe UI Semibold" Foreground="#2E7D32" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#E3F2FD" CornerRadius="4" Padding="12,6">
                        <StackPanel>
                            <TextBlock Text="Unités reçues (Validés)" FontSize="10" Foreground="#1565C0"/>
                            <TextBlock Text="{Binding TotalUnitsReceived}" FontSize="16" FontFamily="Segoe UI Semibold" Foreground="#1565C0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ GRILLE DU JOURNAL ═══════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="1">
            <DataGrid ItemsSource="{Binding Vouchers}" SelectedItem="{Binding SelectedVoucher}"
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" SelectionMode="Single"
                      RowHeight="36" BorderThickness="0" Background="Transparent">
                <DataGrid.Columns>
                    <!-- Actions -->
                    <DataGridTemplateColumn Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Command="{Binding DataContext.EditVoucherCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Content="✏️" Background="Transparent" BorderThickness="0" ToolTip="Ouvrir le bon (édition/consultation)"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="N° Bon" Binding="{Binding VoucherNumber}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Date" Binding="{Binding ReceiptDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Donneur" Binding="{Binding DonorName}" Width="200"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding DonorType}" Width="120"/>
                    <DataGridTextColumn Header="Nb Lignes" Binding="{Binding TotalLines}" Width="80"/>
                    <DataGridTextColumn Header="Unités" Binding="{Binding TotalUnits}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Statut" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusIcon}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding StatusLabel}" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#666"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusLabel}" Value="Validé">
                                                        <Setter Property="Foreground" Value="#2ECC71"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- STATUS -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" VerticalAlignment="Center" HorizontalAlignment="Left"
                   Foreground="{Binding IsStatusError, Converter={StaticResource ErrorToColorConverter}}" FontSize="14" Margin="0,12,0,0"/>

    </Grid>
</UserControl>
