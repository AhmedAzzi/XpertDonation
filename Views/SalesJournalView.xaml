<UserControl x:Class="XDonation.Views.SalesJournalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource WorkspaceBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        

        <!-- ═══ MAIN CONTENT ═══════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Transactions Table -->
            <DataGrid x:Name="SalesGrid"
                      Grid.Row="0"
                      AutoGenerateColumns="False"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="0,1,0,0"
                      RowBackground="White"
                      AlternatingRowBackground="{StaticResource TableAltRowBrush}"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      Margin="24,12,24,0">
                
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                        <Setter Property="Background" Value="{StaticResource TableHeaderBrush}"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="8,8"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Height" Value="36"/>
                        <Setter Property="TextBlock.TextAlignment" Value="Left"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° Vente" Binding="{Binding SaleNumber}" Width="90"/>
                    <DataGridTextColumn Header="Type Vente" Binding="{Binding SaleType}" Width="140"/>
                    <DataGridTextColumn Header="Mont. Vente" Binding="{Binding Amount, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="Motif" Binding="{Binding Reason}" Width="80"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat=G}" Width="160"/>
                    <DataGridTextColumn Header="Clients" Binding="{Binding ClientName}" Width="*"/>
                    <DataGridTextColumn Header="Remise globale" Binding="{Binding GlobalDiscount, StringFormat=N2}" Width="130"/>
                    <DataGridTextColumn Header="Mont. Vente (remisé)" Binding="{Binding DiscountedAmount, StringFormat=N2}" Width="140"/>
                    <DataGridTextColumn Header="Mont. Payé" Binding="{Binding PaidAmount, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="Mont. Reste" Binding="{Binding RemainingAmount, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="Date Éche." Binding="{Binding DueDate, StringFormat=d}" Width="110"/>
                    <DataGridTextColumn Header="Saisie Par" Binding="{Binding EnteredBy}" Width="110"/>
                    <DataGridTextColumn Header="Saisie le" Binding="{Binding EntryDate, StringFormat=G}" Width="160"/>
                    <DataGridTextColumn Header="Nom Machine" Binding="{Binding MachineName}" Width="130"/>
                    <DataGridTextColumn Header="Avec" Binding="{Binding WithInfo}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Detail Section -->
            <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel Margin="24,16,24,16">
                    <TextBlock Text="Détail de la vente"
                               FontFamily="Segoe UI Semibold"
                               FontSize="12"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <DataGrid AutoGenerateColumns="False"
                              BorderBrush="{StaticResource BorderBrush}"
                              BorderThickness="1"
                              RowBackground="White"
                              AlternatingRowBackground="{StaticResource TableAltRowBrush}"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              Height="140">
                        
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                <Setter Property="Background" Value="{StaticResource TableHeaderBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="Height" Value="32"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100"/>
                            <DataGridTextColumn Header="Produit" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Qte" Binding="{Binding Quantity}" Width="60"/>
                            <DataGridTextColumn Header="Lot" Binding="{Binding LotNumber}" Width="100"/>
                            <DataGridTextColumn Header="Date préemp." Binding="{Binding ExpiryDate, StringFormat=d}" Width="130"/>
                            <DataGridTextColumn Header="Code Barre Lot" Binding="{Binding LotBarcode}" Width="120"/>
                            <DataGridTextColumn Header="Prix Vente" Binding="{Binding SalePrice, StringFormat=N2}" Width="110"/>
                            <DataGridTextColumn Header="Mnt. Vente" Binding="{Binding LineAmount, StringFormat=N2}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ FOOTER ═════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="24,12,24,12">
            <Button Content="Nouveau [F10]" 
                    Padding="16,8"
                    FontFamily="Segoe UI Semibold"
                    FontSize="11"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,12,0"/>
            <Button Content="Supprimer [F3]" 
                    Padding="12,8"
                    FontFamily="Segoe UI Semibold"
                    FontSize="11"
                    Background="{StaticResource DangerBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,12,0"/>
            <Button Content="Journal Détaillé" 
                    Padding="12,8"
                    FontFamily="Segoe UI Semibold"
                    FontSize="11"
                    Background="{StaticResource WarningBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,12,0"/>
            <TextBlock Text="Incluie les échanges annés" 
                       Style="{StaticResource LabelStyle}"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
