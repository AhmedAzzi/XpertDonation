<UserControl
    x:Class="XDonation.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:XDonation.ViewModels"
    Background="{StaticResource WorkspaceBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <!--  ═══ MAIN CONTENT ══════════════════════════════════════════════  -->
        <DockPanel Grid.Column="0" Margin="12,10,12,10">

            <!--  Title block — docked top  -->
            <StackPanel Margin="0,0,0,8" DockPanel.Dock="Top">
                 <TextBlock
                     Margin="0,0,0,4"
                     FontFamily="Segoe UI Light"
                     FontSize="22"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Text="Bienvenue dans XDonation" />
                <TextBlock
                    FontFamily="Segoe UI"
                    FontSize="13"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="Système de dispensation de médicaments donnés" />
            </StackPanel>

            <!--  Summary stats bar — docked bottom  -->
            <Border
                Margin="0,6,0,0"
                Padding="16,10"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                DockPanel.Dock="Bottom">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="8"
                        Opacity="0.06"
                        ShadowDepth="2"
                        Color="#000000" />
                </Border.Effect>
                <UniformGrid Columns="3">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="Segoe UI Semibold"
                            FontSize="26"
                            Foreground="{StaticResource AccentBrush}"
                            Text="{Binding TotalDonations}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Références en stock" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="Segoe UI Semibold"
                            FontSize="26"
                            Foreground="{StaticResource SuccessBrush}"
                            Text="{Binding TotalDrugs}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Unités disponibles" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="Segoe UI Semibold"
                            FontSize="26"
                            Foreground="{StaticResource DangerBrush}"
                            Text="{Binding ExpiredLots}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Lots périmés" />
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!--  6 Tiles — fill remaining space with UniformGrid 2×3  -->
            <UniformGrid Columns="3" Rows="2">

                <!--  Tile 1: Comptoir Don  -->
                <Border
                    Margin="0,0,5,5"
                    Background="#1D6CB5"
                    ClipToBounds="True"
                    CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="2"
                            Color="#000000" />
                    </Border.Effect>
                    <Button
                        x:Name="BtnGoComptoir"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnGoComptoir_Click"
                        Foreground="White"
                        Style="{StaticResource TileButtonStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    Text="💊" />
                                <TextBlock
                                    Margin="0,6,0,3"
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI Semibold"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Sorteé" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12.5"
                                    Foreground="White"
                                    Opacity="0.85"
                                    Text="Dispensation de médicaments" />
                            </StackPanel>
                    </Button>
                </Border>

                <!--  Tile 2: Stock  -->
                <Border
                    Margin="0,0,5,5"
                    Background="#0F766E"
                    ClipToBounds="True"
                    CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="2"
                            Color="#000000" />
                    </Border.Effect>
                    <Button
                        x:Name="BtnGoStock"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnGoStock_Click"
                        Foreground="White"
                        Style="{StaticResource TileButtonStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    Text="📦" />
                                <TextBlock
                                    Margin="0,6,0,3"
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI Semibold"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Stock" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12.5"
                                    Foreground="White"
                                    Opacity="0.85"
                                    Text="Lots périmés" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI Semibold"
                                    FontSize="17"
                                    Foreground="White"
                                    Text="{Binding ExpiredLots}" />
                            </StackPanel>
                    </Button>
                </Border>

                <!--  Tile 3: Historique  -->
                <Border
                    Margin="0,0,0,5"
                    Background="#15803D"
                    ClipToBounds="True"
                    CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="2"
                            Color="#000000" />
                    </Border.Effect>
                    <Button
                        x:Name="BtnGoHistory"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnGoHistory_Click"
                        Foreground="White"
                        Style="{StaticResource TileButtonStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    Text="📋" />
                                <TextBlock
                                    Margin="0,6,0,3"
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI Semibold"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Historique" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12.5"
                                    Foreground="White"
                                    Opacity="0.85"
                                    Text="Journal des dispensations" />
                            </StackPanel>
                    </Button>
                </Border>

                <!--  Tile 4: Bons de don  -->
                <Border
                    Margin="0,0,5,0"
                    Background="#B45309"
                    ClipToBounds="True"
                    CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="2"
                            Color="#000000" />
                    </Border.Effect>
                    <Button
                        x:Name="BtnGoVouchers"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnGoVouchers_Click"
                        Foreground="White"
                        Style="{StaticResource TileButtonStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    Text="📄" />
                                <TextBlock
                                    Margin="0,6,0,3"
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI Semibold"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Entreé" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12.5"
                                    Foreground="White"
                                    Opacity="0.85"
                                    Text="Créer et gérer les bons" />
                            </StackPanel>
                    </Button>
                </Border>

                <!--  Tile 5: Journal des bons  -->
                <Border
                    Margin="0,0,5,0"
                    Background="#7C3AED"
                    ClipToBounds="True"
                    CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="2"
                            Color="#000000" />
                    </Border.Effect>
                    <Button
                        x:Name="BtnGoJournal"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnGoJournal_Click"
                        Foreground="White"
                        Style="{StaticResource TileButtonStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    Text="📑" />
                                <TextBlock
                                    Margin="0,6,0,3"
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI Semibold"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Journal des Entreés" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12.5"
                                    Foreground="White"
                                    Opacity="0.85"
                                    Text="Historique des validations" />
                            </StackPanel>
                    </Button>
                </Border>

                <!--  Tile 6: Produits  -->
                <Border
                    Margin="0,0,0,0"
                    Background="#475569"
                    ClipToBounds="True"
                    CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="2"
                            Color="#000000" />
                    </Border.Effect>
                    <Button
                        x:Name="BtnGoProducts"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnGoProducts_Click"
                        Foreground="White"
                        Style="{StaticResource TileButtonStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    Text="🗃️" />
                                <TextBlock
                                    Margin="0,6,0,3"
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI Semibold"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Produits" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12.5"
                                    Foreground="White"
                                    Opacity="0.85"
                                    Text="Catalogue médicaments" />
                            </StackPanel>
                    </Button>
                </Border>

            </UniformGrid>

        </DockPanel>

        <!--  ═══ RIGHT INDICATORS PANEL ══════════════════════════════════════  -->
        <Border
            Grid.Column="1"
            Background="White"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1,0,0,0">
            <DockPanel>

                <Border
                    Padding="14,10"
                    Background="{StaticResource HeaderBrush}"
                    DockPanel.Dock="Top">
                    <TextBlock
                        FontFamily="Segoe UI Semibold"
                        FontSize="15"
                        Foreground="White"
                        Text="Indicateurs" />
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Références totales → All -->
                        <Button Command="{Binding NavigateWithFilterCommand}"
                                CommandParameter="{x:Static vm:StockFilterType.All}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalContentAlignment="Stretch">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Border"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="0,0,0,1"
                                                        Background="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="48" Height="48" Background="#DBEAFE">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="20"
                                               Text="📦" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,6">
                                    <TextBlock FontFamily="Segoe UI"
                                               FontSize="12"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="Références totales" />
                                    <TextBlock FontFamily="Segoe UI Semibold"
                                               FontSize="19"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding TotalDonations}" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Unités disponibles → NonExpired -->
                        <Button Command="{Binding NavigateWithFilterCommand}"
                                CommandParameter="{x:Static vm:StockFilterType.NonExpired}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalContentAlignment="Stretch">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Border"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="0,0,0,1"
                                                        Background="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="48" Height="48" Background="#DCFCE7">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="20"
                                               Text="💊" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,6">
                                    <TextBlock FontFamily="Segoe UI"
                                               FontSize="12"
                                               Foreground="{StaticResource SuccessBrush}"
                                               Text="Unités disponibles" />
                                    <TextBlock FontFamily="Segoe UI Semibold"
                                               FontSize="19"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding TotalDrugs}" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Lots périmés → Expired -->
                        <Button Command="{Binding NavigateWithFilterCommand}"
                                CommandParameter="{x:Static vm:StockFilterType.Expired}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalContentAlignment="Stretch">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Border"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="0,0,0,1"
                                                        Background="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="48" Height="48" Background="#FEE2E2">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="20"
                                               Text="🗑" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,6">
                                    <TextBlock FontFamily="Segoe UI"
                                               FontSize="12"
                                               Foreground="{StaticResource DangerBrush}"
                                               Text="Lots périmés" />
                                    <TextBlock FontFamily="Segoe UI Semibold"
                                               FontSize="19"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding ExpiredLots}" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Périmés dans 30 jours → Exp30Days -->
                        <Button Command="{Binding NavigateWithFilterCommand}"
                                CommandParameter="{x:Static vm:StockFilterType.Exp30Days}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalContentAlignment="Stretch">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Border"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="0,0,0,1"
                                                        Background="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="48" Height="48" Background="#FEF3C7">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="20"
                                               Text="⏰" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,6">
                                    <TextBlock FontFamily="Segoe UI"
                                               FontSize="12"
                                               Foreground="{StaticResource WarningBrush}"
                                               Text="Périmés dans 30 jours" />
                                    <TextBlock FontFamily="Segoe UI Semibold"
                                               FontSize="19"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding ExpiringSoon30}" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Périmés dans 60 jours → Exp60Days -->
                        <Button Command="{Binding NavigateWithFilterCommand}"
                                CommandParameter="{x:Static vm:StockFilterType.Exp60Days}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalContentAlignment="Stretch">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Border"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="0,0,0,1"
                                                        Background="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="48" Height="48" Background="#FEF3C7">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="20"
                                               Text="⏰" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,6">
                                    <TextBlock FontFamily="Segoe UI"
                                               FontSize="12"
                                               Foreground="{StaticResource WarningBrush}"
                                               Text="Périmés dans 60 jours" />
                                    <TextBlock FontFamily="Segoe UI Semibold"
                                               FontSize="19"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding ExpiringSoon60}" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Périmés dans 90 jours → Exp90Days -->
                        <Button Command="{Binding NavigateWithFilterCommand}"
                                CommandParameter="{x:Static vm:StockFilterType.Exp90Days}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalContentAlignment="Stretch">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Border"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="0,0,0,1"
                                                        Background="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="48" Height="48" Background="#FEF3C7">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="20"
                                               Text="⏰" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,6">
                                    <TextBlock FontFamily="Segoe UI"
                                               FontSize="12"
                                               Foreground="{StaticResource WarningBrush}"
                                               Text="Périmés dans 90 jours" />
                                    <TextBlock FontFamily="Segoe UI Semibold"
                                               FontSize="19"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding ExpiringSoon90}" />
                                </StackPanel>
                            </Grid>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

    </Grid>
</UserControl>
