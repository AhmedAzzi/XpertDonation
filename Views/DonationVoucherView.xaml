<UserControl
    x:Class="XDonation.Views.DonationVoucherView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:XDonation.Converters"
    xmlns:ctrl="clr-namespace:XDonation.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:XDonation.ViewModels"
    d:DesignHeight="720"
    d:DesignWidth="1080"
    Background="{StaticResource WorkspaceBrush}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:WidthOffsetConverter x:Key="WidthOffset" />
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F8" Command="{Binding ValidateVoucherCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Header: title + fields  -->
            <RowDefinition Height="Auto" />
            <!--  Line entry form  -->
            <RowDefinition Height="Auto" />
            <!--  DataGrid column headers  -->
            <RowDefinition Height="*" />
            <!--  DataGrid content  -->
            <RowDefinition Height="Auto" />
            <!--  Footer  -->
        </Grid.RowDefinitions>

        <!--  ═══ HEADER SECTION ═══════════════════════════════════════════  -->
        <StackPanel Grid.Row="0" Margin="20,12,20,0">
            <!--  Title  -->
            <TextBlock
                Margin="0,0,0,12"
                FontFamily="Segoe UI Semibold"
                FontSize="15"
                Foreground="{StaticResource AccentBrush}"
                Text="NOUVELLE ENTRÉE" />

            <!--  Header Fields Box  -->
            <Border
                Padding="12,10"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="8*" />
                    </Grid.ColumnDefinitions>

                    <!--  Date de réception  -->
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontFamily="Segoe UI"
                            FontSize="11"
                            Foreground="#666"
                            Text="Date de réception :" />
                        <ctrl:DateInputBox
                            MinHeight="28"
                            Date="{Binding ReceiptDate, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="{Binding CanEdit}" />
                    </StackPanel>

                    <!--  Notes / Observations  -->
                    <StackPanel Grid.Column="2">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontFamily="Segoe UI"
                            FontSize="11"
                            Foreground="#666"
                            Text="Notes / Observations :" />
                        <TextBox
                            MinHeight="28"
                            Padding="8,4"
                            VerticalContentAlignment="Center"
                            Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            IsEnabled="{Binding CanEdit}"
                            Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <!--  ═══ LINE ENTRY FORM ═══════════════════════════════════════════  -->
        <Border
            Grid.Row="1"
            Margin="16,12,16,8"
            Padding="8,4"
            Background="White"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
            <Grid Visibility="{Binding CanEdit, Converter={StaticResource BoolToVisConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <!--  Code Fab.  -->
                    <ColumnDefinition Width="2.8*" />
                    <!--  Médicament + btn  -->
                    <ColumnDefinition Width="1.5*" />
                    <!--  DCI  -->
                    <ColumnDefinition Width="1.2*" />
                    <!--  N° Lot  -->
                    <ColumnDefinition Width="170" />
                    <!--  Expiration  -->
                    <ColumnDefinition Width="60" />
                    <!--  Qté  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  Button  -->
                </Grid.ColumnDefinitions>

                <!--  Code Fabricant  -->
                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <TextBlock
                        Margin="0,0,0,2"
                        FontSize="10"
                        Foreground="#3B82F6"
                        FontWeight="SemiBold"
                        Text="Code Fab. 🏷️" />
                    <TextBox
                        x:Name="TxtCodeFab"
                        MinHeight="26"
                        Padding="4,2"
                        BorderBrush="#3B82F6"
                        BorderThickness="1.5"
                        FontFamily="Segoe UI"
                        FontSize="11"
                        ToolTip="Scanner ou saisir le code-barres fabricant"
                        Text="{Binding InputCodeBarresFabricant, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ScanManufacturerBarcodeCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>

                <!--  Médicament *  -->
                <StackPanel Grid.Column="1" Margin="0,0,6,0">
                    <TextBlock
                        Margin="0,0,0,2"
                        FontSize="10"
                        Foreground="#888"
                        Text="Médicament *" />
                    <Grid x:Name="DrugSearchGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!--  TextBox with embedded toggle area  -->
                        <Border
                            x:Name="DrugSearchBorder"
                            Grid.Column="0"
                            Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="24" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="DrugTextBox"
                                    Grid.Column="0"
                                    Padding="4,2"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    LostKeyboardFocus="DrugTextBox_LostKeyboardFocus"
                                    PreviewKeyDown="DrugTextBox_PreviewKeyDown"
                                    Text="{Binding InputDrugName, UpdateSourceTrigger=PropertyChanged}" />
                                <!--  Dropdown toggle button  -->
                                <ToggleButton
                                    x:Name="ToggleDropdownBtn"
                                    Grid.Column="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    IsChecked="{Binding IsSuggestionOpen, Mode=TwoWay}">
                                    <Path
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M 0 0 L 4 4 L 8 0 Z"
                                        Fill="#94A3B8"
                                        SnapsToDevicePixels="True" />
                                </ToggleButton>
                            </Grid>
                        </Border>
                        <Button
                            Grid.Column="1"
                            MinWidth="24"
                            MinHeight="26"
                            Margin="2,0,0,0"
                            Padding="0"
                            VerticalAlignment="Bottom"
                            Background="Transparent"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1,1,1,1"
                            Click="OptionsBtn_Click"
                            Content="..."
                            Cursor="Hand"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#64748B"
                            ToolTip="Options produit">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Command="{Binding CreateNewDrugCommand}" Header="Nouveau" />
                                    <MenuItem Command="{Binding ShowDrugDialogCommand}" Header="Modifier" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>
                    <!--  Suggestions Dropdown Popup  -->
                    <Popup
                        x:Name="SuggestionsPopup"
                        Width="{Binding ActualWidth, ElementName=DrugSearchGrid, Converter={StaticResource WidthOffset}, ConverterParameter=40}"
                        MaxHeight="250"
                        AllowsTransparency="True"
                        HorizontalOffset="-20"
                        IsOpen="{Binding IsSuggestionOpen}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=DrugSearchGrid}"
                        StaysOpen="False">
                        <Border
                            Margin="0,0,0,0"
                            Background="White"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="0,0,6,6"
                            SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="12"
                                    Direction="270"
                                    Opacity="0.12"
                                    ShadowDepth="2"
                                    Color="#000000" />
                            </Border.Effect>
                            <ListBox
                                x:Name="SuggestionsList"
                                MaxHeight="250"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding DrugSuggestions}"
                                KeyDown="SuggestionsList_KeyDown"
                                MouseDoubleClick="SuggestionsList_MouseDoubleClick"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                SelectionMode="Single">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,4" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ListBoxItem_PreviewMouseLeftButtonDown" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border
                                                        x:Name="bg"
                                                        Padding="{TemplateBinding Padding}"
                                                        SnapsToDevicePixels="True">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bg" Property="Background" Value="#EFF6FF" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="bg" Property="Background" Value="#DBEAFE" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                FontFamily="Segoe UI Semibold"
                                                FontSize="12"
                                                Foreground="#1E293B"
                                                Text="{Binding Name}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="6,0,0,0"
                                                FontFamily="Segoe UI"
                                                FontSize="10"
                                                Foreground="#94A3B8"
                                                Text="{Binding Dci, StringFormat='| {0}'}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </StackPanel>

                <!--  DCI  -->
                <StackPanel Grid.Column="2" Margin="0,0,6,0">
                    <TextBlock
                        Margin="0,0,0,2"
                        FontSize="10"
                        Foreground="#888"
                        Text="DCI" />
                    <TextBox
                        MinHeight="26"
                        Padding="4,2"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        FontFamily="Segoe UI"
                        FontSize="11"
                        Text="{Binding InputDci, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!--  N° Lot  -->
                <StackPanel Grid.Column="3" Margin="0,0,6,0">
                    <TextBlock
                        Margin="0,0,0,2"
                        FontSize="10"
                        Foreground="#888"
                        Text="N° Lot" />
                    <TextBox
                        x:Name="LotTextBox"
                        MinHeight="26"
                        Padding="4,2"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        FontFamily="Segoe UI"
                        FontSize="11"
                        Text="{Binding InputBatchNumber, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!--  Expiration  -->
                <StackPanel Grid.Column="4" Margin="0,0,6,0">
                    <TextBlock
                        Margin="0,0,0,2"
                        FontSize="10"
                        Foreground="#888"
                        Text="Expiration" />
                    <ctrl:DateInputBox MinHeight="26" Date="{Binding InputExpirationDate, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!--  Qté *  -->
                <StackPanel Grid.Column="5" Margin="0,0,6,0">
                    <TextBlock
                        Margin="0,0,0,2"
                        FontSize="10"
                        Foreground="#888"
                        Text="Qté *" />
                    <TextBox
                        MinHeight="26"
                        Padding="4,2"
                        HorizontalContentAlignment="Center"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        FontFamily="Segoe UI"
                        FontSize="11"
                        Text="{Binding InputQuantity, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!--  Aj. Ligne button  -->
                <StackPanel
                    Grid.Column="6"
                    Margin="4,0,0,0"
                    VerticalAlignment="Bottom">
                    <Button
                        MinWidth="70"
                        MinHeight="26"
                        Padding="12,0"
                        Command="{Binding AddLineCommand}"
                        Content="{Binding IsLineEditMode, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Maj. Ligne|Ajt. Ligne'}"
                        Style="{StaticResource PrimaryButtonStyle}" />
                    <Button
                        Margin="0,4,0,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding CancelLineEditCommand}"
                        Content="Annuler modif."
                        FontSize="10"
                        Foreground="#7F8C8D"
                        Visibility="{Binding IsLineEditMode, Converter={StaticResource BoolToVisConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  ═══ LINES DATA GRID ═══════════════════════════════════════════  -->
        <DataGrid
            x:Name="LinesDataGrid"
            Grid.Row="2"
            Grid.RowSpan="2"
            Margin="16,0,16,0"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            ItemsSource="{Binding Lines}"
            SelectedItem="{Binding SelectedLine}"
            Style="{StaticResource AppDataGridStyle}">
            <DataGrid.Resources>
                <ContextMenu x:Key="RowContextMenu">
                    <MenuItem
                        Click="CopyCellMenuItem_Click"
                        Header="Copier" />
                    <Separator />
                    <MenuItem
                        Command="{Binding DataContext.PrintBarcodeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding}"
                        Header="Imprimer code-barres" />
                    <Separator />
                    <MenuItem
                        Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding}"
                        Header="Supprimer la ligne" />
                </ContextMenu>
            </DataGrid.Resources>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource AppDataGridCellStyle}">
                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="DataGridCell_PreviewMouseRightButtonDown" />
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource AppDataGridRowStyle}">
                    <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}" />
                    <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick" />
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding DrugName}"
                    Header="Médicament" />
                <DataGridTextColumn
                    Width="1.5*"
                    Binding="{Binding Dci}"
                    Header="DCI" />
                <DataGridTextColumn
                    Width="1.2*"
                    Binding="{Binding CodeBarresFabricant}"
                    Header="Code Fab." />
                <DataGridTextColumn
                    Width="1.2*"
                    Binding="{Binding Barcode}"
                    Header="Code Barres" />
                <DataGridTextColumn
                    Width="1*"
                    Binding="{Binding BatchNumber}"
                    Header="Lot" />
                <DataGridTextColumn
                    Width="0.8*"
                    Binding="{Binding ExpirationLabel}"
                    Header="Exp." />
                <DataGridTextColumn
                    Width="0.6*"
                    Binding="{Binding Quantity}"
                    Header="Qté">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>


            </DataGrid.Columns>
        </DataGrid>

        <!--  ═══ FOOTER ═══════════════════════════════════════════════════  -->
        <Border
            Grid.Row="4"
            Padding="16,8"
            Background="White"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <!--  Status message  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  Totals  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  Cancel  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  Validate  -->
                </Grid.ColumnDefinitions>

                <!--  Status message  -->
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    Foreground="{Binding IsStatusError, Converter={StaticResource ErrorToColorConverter}}"
                    Text="{Binding StatusMessage}" />

                <!--  Totals  -->
                <StackPanel
                    Grid.Column="1"
                    Margin="0,0,16,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#666"
                        Text="Total lignes : " />
                    <TextBlock
                        Margin="0,0,16,0"
                        VerticalAlignment="Center"
                        FontFamily="Segoe UI Semibold"
                        FontSize="13"
                        Foreground="{StaticResource PrimaryDarkBrush}"
                        Text="{Binding TotalLines}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#666"
                        Text="Unités : " />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="Segoe UI Semibold"
                        FontSize="13"
                        Foreground="{StaticResource PrimaryDarkBrush}"
                        Text="{Binding TotalUnits}" />
                </StackPanel>

                <!--  Cancel button  -->
                <Button
                    Grid.Column="2"
                    MinHeight="34"
                    Margin="0,0,8,0"
                    Padding="16,0"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource GhostButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Text="✕" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Text="Annuler (ESC)" />
                    </StackPanel>
                </Button>

                <!--  Validate button  -->
                <Button
                    Grid.Column="3"
                    MinWidth="140"
                    MinHeight="34"
                    Padding="24,0"
                    Command="{Binding ValidateVoucherCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Visibility="{Binding CanEdit, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock FontFamily="Segoe UI Semibold" Text="{Binding ValidateActionLabel, StringFormat='{}{0} (F8)'}" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
