<UserControl x:Class="XpertPharm5Donation.Views.DonationVoucherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:XpertPharm5Donation.ViewModels"
             xmlns:conv="clr-namespace:XpertPharm5Donation.Converters"
             xmlns:ctrl="clr-namespace:XpertPharm5Donation.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080"
             Background="{StaticResource WorkspaceBrush}">

    <UserControl.Resources>
        <conv:WidthOffsetConverter x:Key="WidthOffset"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F8" Command="{Binding ValidateVoucherCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header: title + fields -->
            <RowDefinition Height="Auto"/>  <!-- Line entry form -->
            <RowDefinition Height="Auto"/>  <!-- DataGrid column headers -->
            <RowDefinition Height="*"/>     <!-- DataGrid content -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER SECTION ═══════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Margin="20,12,20,0">
            <!-- Title -->
            <TextBlock Text="NOUVEAU BON DE DON" 
                       FontFamily="Segoe UI Semibold" FontSize="15" 
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,12"/>

            <!-- Header Fields Box -->
            <Border Background="White" BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" CornerRadius="4" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Date de réception -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Date de réception :" 
                                   FontFamily="Segoe UI" FontSize="11" 
                                   Foreground="#666" Margin="0,0,0,4"/>
                        <ctrl:DateInputBox Date="{Binding ReceiptDate, UpdateSourceTrigger=PropertyChanged}"
                                           IsEnabled="{Binding CanEdit}"
                                           MinHeight="28"/>
                    </StackPanel>

                    <!-- Donneur -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Donneur :" 
                                   FontFamily="Segoe UI" FontSize="11" 
                                   Foreground="#666" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding DonorName, UpdateSourceTrigger=PropertyChanged}" 
                                 IsEnabled="{Binding CanEdit}"
                                 MinHeight="28" Padding="8,4" 
                                 FontFamily="Segoe UI" FontSize="12"
                                 Background="White"
                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Notes / Observations -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Notes / Observations :" 
                                   FontFamily="Segoe UI" FontSize="11" 
                                   Foreground="#666" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" 
                                 IsEnabled="{Binding CanEdit}"
                                 MinHeight="28" Padding="8,4" 
                                 FontFamily="Segoe UI" FontSize="12"
                                 Background="White"
                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <!-- ═══ LINE ENTRY FORM ═══════════════════════════════════════════ -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                Background="White" Margin="16,12,16,8" Padding="8,4">
            <Grid Visibility="{Binding CanEdit, Converter={StaticResource BoolToVisConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/> <!-- Code-barres -->
                    <ColumnDefinition Width="2.5*"/>   <!-- Médicament + btn -->
                    <ColumnDefinition Width="1.5*"/>   <!-- DCI -->
                    <ColumnDefinition Width="1.2*"/> <!-- N° Lot -->
                    <ColumnDefinition Width="100"/>  <!-- Expiration -->
                    <ColumnDefinition Width="60"/>   <!-- Qté -->
                    <ColumnDefinition Width="Auto"/> <!-- Button -->
                </Grid.ColumnDefinitions>

                <!-- Code-barres -->
                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <TextBlock Text="Code-barres" FontSize="10" Foreground="#888" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtBarcode" 
                             Text="{Binding InputBarcode, UpdateSourceTrigger=PropertyChanged}" 
                             MinHeight="26" Padding="4,2" FontFamily="Segoe UI" FontSize="11"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>

                <!-- Médicament * -->
                <StackPanel Grid.Column="1" Margin="0,0,6,0">
                    <TextBlock Text="Médicament *" FontSize="10" Foreground="#888" Margin="0,0,0,2"/>
                    <Grid x:Name="DrugSearchGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- TextBox with embedded toggle area -->
                        <Border x:Name="DrugSearchBorder"
                                Grid.Column="0"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="DrugTextBox"
                                         Grid.Column="0"
                                         Text="{Binding InputDrugName, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="4,2"
                                         FontFamily="Segoe UI"
                                         FontSize="12"
                                         VerticalContentAlignment="Center"
                                         PreviewKeyDown="DrugTextBox_PreviewKeyDown"
                                         LostKeyboardFocus="DrugTextBox_LostKeyboardFocus"/>
                                <!-- Dropdown toggle button -->
                                <ToggleButton x:Name="ToggleDropdownBtn"
                                              Grid.Column="1"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsSuggestionOpen, Mode=TwoWay}"
                                              Cursor="Hand">
                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="#94A3B8"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          SnapsToDevicePixels="True"/>
                                </ToggleButton>
                            </Grid>
                        </Border>
                        <Button Grid.Column="1" Content="+" MinWidth="24" MinHeight="26"
                                FontSize="14" FontWeight="Bold" Padding="0"
                                Background="#1D6CB5" BorderBrush="#1D6CB5" BorderThickness="0,1,1,1"
                                Command="{Binding ShowDrugDialogCommand}" Cursor="Hand"
                                Foreground="White"
                                VerticalAlignment="Bottom" ToolTip="Ajouter un nouveau produit"/>
                    </Grid>
                    <!-- Suggestions Dropdown Popup -->
                    <Popup x:Name="SuggestionsPopup"
                           IsOpen="{Binding IsSuggestionOpen}"
                           StaysOpen="False"
                           PlacementTarget="{Binding ElementName=DrugSearchGrid}"
                           Placement="Bottom"
                           HorizontalOffset="-20"
                           Width="{Binding ActualWidth, ElementName=DrugSearchGrid, Converter={StaticResource WidthOffset}, ConverterParameter=40}"
                           MaxHeight="250"
                           AllowsTransparency="True">
                        <Border Background="White"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="0,0,6,6"
                                Margin="0,0,0,0"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="12" Opacity="0.12" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ListBox x:Name="SuggestionsList"
                                     ItemsSource="{Binding DrugSuggestions}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     MaxHeight="250"
                                     SelectionMode="Single"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     KeyDown="SuggestionsList_KeyDown"
                                     MouseDoubleClick="SuggestionsList_MouseDoubleClick">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,4"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="bg" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bg" Property="Background" Value="#EFF6FF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="bg" Property="Background" Value="#DBEAFE"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontFamily="Segoe UI Semibold"
                                                       FontSize="12"
                                                       Foreground="#1E293B"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Dci, StringFormat='| {0}'}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="10"
                                                       Foreground="#94A3B8"
                                                       Margin="6,0,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </StackPanel>

                <!-- DCI -->
                <StackPanel Grid.Column="2" Margin="0,0,6,0">
                    <TextBlock Text="DCI" FontSize="10" Foreground="#888" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding InputDci, UpdateSourceTrigger=PropertyChanged}" 
                             MinHeight="26" Padding="4,2" FontFamily="Segoe UI" FontSize="11"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                </StackPanel>

                <!-- N° Lot -->
                <StackPanel Grid.Column="3" Margin="0,0,6,0">
                    <TextBlock Text="N° Lot" FontSize="10" Foreground="#888" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding InputBatchNumber, UpdateSourceTrigger=PropertyChanged}" 
                             MinHeight="26" Padding="4,2" FontFamily="Segoe UI" FontSize="11"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                </StackPanel>

                <!-- Expiration -->
                <StackPanel Grid.Column="4" Margin="0,0,6,0">
                    <TextBlock Text="Expiration" FontSize="10" Foreground="#888" Margin="0,0,0,2"/>
                    <ctrl:DateInputBox Date="{Binding InputExpirationDate, UpdateSourceTrigger=PropertyChanged}"
                                       MinHeight="26"/>
                </StackPanel>

                <!-- Qté * -->
                <StackPanel Grid.Column="5" Margin="0,0,6,0">
                    <TextBlock Text="Qté *" FontSize="10" Foreground="#888" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding InputQuantity, UpdateSourceTrigger=PropertyChanged}" 
                             MinHeight="26" Padding="4,2" FontFamily="Segoe UI" FontSize="11"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             HorizontalContentAlignment="Center"/>
                </StackPanel>

                <!-- Aj. Ligne button -->
                <StackPanel Grid.Column="6" VerticalAlignment="Bottom" Margin="4,0,0,0">
                    <Button Content="{Binding IsLineEditMode, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Maj. Ligne|Ajt. Ligne'}"
                            Command="{Binding AddLineCommand}" 
                            MinHeight="26" Padding="12,0" MinWidth="70"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Content="Annuler modif." Command="{Binding CancelLineEditCommand}" Margin="0,4,0,0"
                            Visibility="{Binding IsLineEditMode, Converter={StaticResource BoolToVisConverter}}"
                            Background="Transparent" BorderThickness="0" Foreground="#7F8C8D" FontSize="10"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ LINES DATA GRID ═══════════════════════════════════════════ -->
        <DataGrid Grid.Row="2" Grid.RowSpan="2"
                  ItemsSource="{Binding Lines}" SelectedItem="{Binding SelectedLine}"
                  Style="{StaticResource AppDataGridStyle}"
                  Margin="16,0,16,0"
                  BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                <DataGrid.Resources>
                    <ContextMenu x:Key="RowContextMenu">
                        <MenuItem Header="Imprimer code-barres" Command="{Binding DataContext.PrintBarcodeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                    </ContextMenu>
                </DataGrid.Resources>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}" />
                    </Style>
                </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Médicament" Binding="{Binding DrugName}" Width="2*"/>
                <DataGridTextColumn Header="DCI" Binding="{Binding Dci}" Width="1.5*"/>
                <DataGridTextColumn Header="Code Barres" Binding="{Binding Barcode}" Width="1.2*"/>
                <DataGridTextColumn Header="Lot" Binding="{Binding BatchNumber}" Width="1*"/>
                <DataGridTextColumn Header="Exp." Binding="{Binding ExpirationLabel}" Width="0.8*"/>
                <DataGridTextColumn Header="Qté" Binding="{Binding Quantity}" Width="0.6*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Actions (hidden column for edit/remove) -->
                <DataGridTemplateColumn Width="0.8*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Command="{Binding DataContext.EditLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" Content="✏️" Background="Transparent" BorderThickness="0" Opacity="0.7" FontSize="10"/>
                                <Button Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" Content="❌" Background="Transparent" BorderThickness="0" Opacity="0.7" Margin="2,0,0,0" FontSize="10"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══ FOOTER ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="White" BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>   <!-- Status message -->
                    <ColumnDefinition Width="Auto"/> <!-- Totals -->
                    <ColumnDefinition Width="Auto"/> <!-- Cancel -->
                    <ColumnDefinition Width="Auto"/> <!-- Validate -->
                </Grid.ColumnDefinitions>

                <!-- Status message -->
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" 
                           VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="12"
                           Foreground="{Binding IsStatusError, Converter={StaticResource ErrorToColorConverter}}"/>

                <!-- Totals -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="Total lignes : " Foreground="#666" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalLines}" FontFamily="Segoe UI Semibold" FontSize="13" 
                               Foreground="{StaticResource PrimaryDarkBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Unités : " Foreground="#666" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalUnits}" FontFamily="Segoe UI Semibold" FontSize="13" 
                               Foreground="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Cancel button -->
                <Button Grid.Column="2" Command="{Binding CancelCommand}" 
                        MinHeight="34" Padding="16,0" Margin="0,0,8,0"
                        Style="{StaticResource GhostButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Annuler (ESC)" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Validate button -->
                <Button Grid.Column="3" Command="{Binding ValidateVoucherCommand}" 
                        Visibility="{Binding CanEdit, Converter={StaticResource BoolToVisConverter}}"
                        MinHeight="34" Padding="24,0" MinWidth="140"
                        Style="{StaticResource PrimaryButtonStyle}">
                    <TextBlock Text="{Binding ValidateActionLabel, StringFormat='{}{0} (F8)'}" FontFamily="Segoe UI Semibold"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
