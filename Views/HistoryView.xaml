<UserControl x:Class="XpertPharm5Donation.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:XpertPharm5Donation.Converters"
             Background="{StaticResource WorkspaceBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:DateToStringConverter x:Key="DateStr"/>
        <conv:NullToStringConverter x:Key="NullStr"/>
    </UserControl.Resources>

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- ═══ FILTER BAR ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="16,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="6" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Date Début :" Style="{StaticResource LabelStyle}" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}"
                            Style="{StaticResource DatePickerStyle}"/>

                <TextBlock Grid.Column="3" Text="Date Fin :" Style="{StaticResource LabelStyle}" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="4" SelectedDate="{Binding EndDate}"
                            Style="{StaticResource DatePickerStyle}"/>

                <StackPanel Grid.Column="6" Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusMessage}" FontFamily="Segoe UI" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="🔍  Filtrer" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding FilterCommand}" Width="110"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SESSIONS MASTER GRID ═══════════════════════════════════ -->
        <Border Grid.Row="2" Background="White" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="6" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource TableHeaderBrush}"
                        CornerRadius="8,8,0,0" Padding="16,10">
                    <TextBlock Text="Sessions de dispensation" FontFamily="Segoe UI Semibold"
                               FontSize="13" Foreground="White"/>
                </Border>

                <DataGrid Grid.Row="1" x:Name="SessionsGrid"
                          Style="{StaticResource AppDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource DataGridCellStyle}"
                          RowStyle="{StaticResource DataGridRowStyle}"
                          ItemsSource="{Binding Sessions}"
                          SelectedItem="{Binding SelectedSession}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date / Heure" Width="200"
                                            Binding="{Binding DateDisplay}"
                                            ElementStyle="{StaticResource ValueStyle}"/>
                        <DataGridTextColumn Header="Lignes" Width="80"
                                            Binding="{Binding TotalLines}"
                                            ElementStyle="{StaticResource ValueStyle}"/>
                        <DataGridTextColumn Header="Unités dispensées" Width="150"
                                            Binding="{Binding TotalUnits}"
                                            ElementStyle="{StaticResource ValueStyle}"/>
                        <DataGridTextColumn Header="Session ID" Width="*"
                                            Binding="{Binding SessionId}"
                                            ElementStyle="{StaticResource LabelStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ═══ DETAIL GRID ══════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="White" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="6" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1A3A6B" CornerRadius="8,8,0,0" Padding="16,10">
                    <TextBlock Text="Détail de la session" FontFamily="Segoe UI Semibold"
                               FontSize="13" Foreground="White"/>
                </Border>

                <DataGrid Grid.Row="1"
                          Style="{StaticResource AppDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource DataGridCellStyle}"
                          RowStyle="{StaticResource DataGridRowStyle}"
                          ItemsSource="{Binding DetailItems}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Médicament" Width="*"
                                            Binding="{Binding StockBatch.Drug.Name}"
                                            ElementStyle="{StaticResource ValueStyle}"/>
                        <DataGridTextColumn Header="Lot Utilisé" Width="120"
                                            Binding="{Binding StockBatch.BatchNumber}"
                                            ElementStyle="{StaticResource LabelStyle}"/>
                        <DataGridTextColumn Header="Date péremption" Width="140"
                                            Binding="{Binding StockBatch.ExpirationDate, Converter={StaticResource DateStr}}"
                                            ElementStyle="{StaticResource LabelStyle}"/>
                        <DataGridTextColumn Header="Qté dispensée" Width="130"
                                            Binding="{Binding Quantity}"
                                            ElementStyle="{StaticResource ValueStyle}"/>
                        <DataGridTextColumn Header="Heure" Width="150"
                                            Binding="{Binding Date, StringFormat='HH:mm:ss'}"
                                            ElementStyle="{StaticResource LabelStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
