<Window x:Class="XpertPharm5Donation.Views.BarcodeLabelDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:XpertPharm5Donation.Views"
    Title="Impression Code-Barres" Height="440" Width="720"
    WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
    Background="#F5F5F5" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="OptionCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="18" Height="18" CornerRadius="3"
                                    Background="White" BorderBrush="#CCC" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Border x:Name="CheckMark" Visibility="Collapsed" CornerRadius="2"
                                        Background="#2196F3" Margin="3">
                                    <Path Data="M0,4 L3,7 L8,0" Stroke="White" StrokeThickness="2"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                            <TextBlock Text="{TemplateBinding Content}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#2196F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL - Options -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Text="OPTIONS D'IMPRESSION"
                           FontWeight="Bold" FontSize="11" Foreground="#888"
                           Margin="0,0,0,12"/>

                <!-- Fields -->
                <StackPanel Grid.Row="1">
                    <CheckBox Style="{StaticResource OptionCheckBox}" Content="Nom pharmacie" IsChecked="{Binding ShowPharmacyName}"/>
                    <Separator Margin="0,4" Opacity="0.3"/>
                    <CheckBox Style="{StaticResource OptionCheckBox}" Content="Image code-barres" IsChecked="{Binding ShowBarcodeImage}"/>
                    <CheckBox Style="{StaticResource OptionCheckBox}" Content="N° code-barres" IsChecked="{Binding ShowBarcodeNumber}"/>
                    <Separator Margin="0,4" Opacity="0.3"/>
                    <CheckBox Style="{StaticResource OptionCheckBox}" Content="Nom produit" IsChecked="{Binding ShowProductName}"/>
                    <CheckBox Style="{StaticResource OptionCheckBox}" Content="Prix" IsChecked="{Binding ShowPrice}"/>
                    <Separator Margin="0,4" Opacity="0.3"/>
                    <CheckBox Style="{StaticResource OptionCheckBox}" Content="Date expiration" IsChecked="{Binding ShowExpiry}"/>
                    <CheckBox Style="{StaticResource OptionCheckBox}" Content="N° Lot" IsChecked="{Binding ShowLot}"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button Style="{StaticResource ActionBtn}" Content="Imprimer" Command="{Binding PrintCommand}"
                            Background="#2196F3" Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Style="{StaticResource ActionBtn}" Content="Fermer" Command="{Binding CloseCommand}" Margin="0"
                            Background="#E0E0E0" Foreground="#555"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- RIGHT PANEL - Preview -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="APERÇU" FontWeight="Bold" FontSize="11" Foreground="#888" Margin="0,0,0,12"/>

            <!-- Preview Card -->
            <Border Grid.Row="1" Background="White" CornerRadius="8"
                    BorderBrush="#DDD" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Direction="270" ShadowDepth="4" BlurRadius="12" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <!-- Background pattern -->
                    <Grid.Background>
                        <DrawingBrush Viewport="0,0,20,20" ViewportUnits="Absolute" TileMode="Tile" Opacity="0.03">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="#000">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,20,20"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Grid.Background>

                    <Viewbox Stretch="Uniform" Margin="20">
                        <local:BarcodeLabelPreview DataContext="{Binding}" Width="340" Height="180"/>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
