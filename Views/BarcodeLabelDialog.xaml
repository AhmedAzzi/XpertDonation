<Window
    x:Class="XpertPharm5Donation.Views.BarcodeLabelDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:XpertPharm5Donation.Views"
    Title="Impression Code-Barres"
    Width="980"
    Height="610"
    MinWidth="840"
    MinHeight="520"
    Background="{StaticResource WorkspaceBrush}"
    FontFamily="Segoe UI"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="OptionCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border
                            x:Name="Row"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    VerticalAlignment="Center"
                                    Background="White"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <Path
                                        x:Name="CheckMark"
                                        Width="9"
                                        Height="7"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M1,4 L4,7 L10,1"
                                        Opacity="0"
                                        Stroke="White"
                                        StrokeEndLineCap="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="2" />
                                </Border>

                                <TextBlock
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="{TemplateBinding Content}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="{StaticResource SelectionBrush}" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="#BFDBFE" />
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="CheckMark" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Row" Property="Background" Value="#EFF6FF" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="#BFDBFE" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  LEFT PANEL - Options  -->
        <Border
            Grid.Column="0"
            Background="White"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,1,0">
            <Grid Margin="28,30,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Header  -->
                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,22"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="OPTIONS D'IMPRESSION" />

                <!--  Fields  -->
                <StackPanel Grid.Row="1">
                    <CheckBox
                        Content="Nom pharmacie"
                        IsChecked="{Binding ShowPharmacyName}"
                        Style="{StaticResource OptionCheckBox}" />
                    <Separator Margin="0,2,0,12" Opacity="0.35" />
                    <CheckBox
                        Content="Image code-barres"
                        IsChecked="{Binding ShowBarcodeImage}"
                        Style="{StaticResource OptionCheckBox}" />
                    <CheckBox
                        Content="N° code-barres"
                        IsChecked="{Binding ShowBarcodeNumber}"
                        Style="{StaticResource OptionCheckBox}" />
                    <Separator Margin="0,2,0,12" Opacity="0.35" />
                    <CheckBox
                        Content="Nom produit"
                        IsChecked="{Binding ShowProductName}"
                        Style="{StaticResource OptionCheckBox}" />
                    <CheckBox
                        Content="Prix"
                        IsChecked="{Binding ShowPrice}"
                        Style="{StaticResource OptionCheckBox}" />
                    <Separator Margin="0,2,0,12" Opacity="0.35" />
                    <CheckBox
                        Content="Date expiration"
                        IsChecked="{Binding ShowExpiry}"
                        Style="{StaticResource OptionCheckBox}" />
                    <CheckBox
                        Content="N° Lot"
                        IsChecked="{Binding ShowLot}"
                        Style="{StaticResource OptionCheckBox}" />
                </StackPanel>

                <!--  Buttons  -->
                <StackPanel
                    Grid.Row="2"
                    Margin="0,22,0,0"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal">
                    <Button
                        Background="{StaticResource AccentBrush}"
                        Command="{Binding PrintCommand}"
                        Content="Imprimer"
                        Foreground="White"
                        Style="{StaticResource ActionBtn}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button
                        Margin="0"
                        Background="#E2E8F0"
                        Command="{Binding CloseCommand}"
                        Content="Fermer"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Style="{StaticResource ActionBtn}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  RIGHT PANEL - Preview  -->
        <Grid Grid.Column="1" Margin="34,30,34,34">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="APERÇU" />

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="ZOOM" />
                    <Button
                        Command="{Binding ZoomOutCommand}"
                        Content="-"
                        Style="{StaticResource IconButton}" />
                    <Slider
                        Width="150"
                        Margin="10,0,6,0"
                        VerticalAlignment="Center"
                        IsSnapToTickEnabled="True"
                        Maximum="2.4"
                        Minimum="0.6"
                        TickFrequency="0.1"
                        Value="{Binding PreviewZoom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Width="48"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="{Binding PreviewZoomPercent}"
                        TextAlignment="Center" />
                    <Button
                        Command="{Binding ZoomInCommand}"
                        Content="+"
                        Style="{StaticResource IconButton}" />
                    <Button
                        Width="58"
                        Command="{Binding ResetZoomCommand}"
                        Content="100%"
                        FontSize="12"
                        Style="{StaticResource IconButton}" />
                </StackPanel>
            </Grid>

            <!--  Preview Card  -->
            <Border
                Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="16"
                        Direction="270"
                        Opacity="0.12"
                        ShadowDepth="5"
                        Color="#000" />
                </Border.Effect>
                <Grid>
                    <!--  Background pattern  -->
                    <Grid.Background>
                        <DrawingBrush
                            Opacity="0.03"
                            TileMode="Tile"
                            Viewport="0,0,20,20"
                            ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="#000">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,20,20" />
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Grid.Background>

                    <ScrollViewer
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <Grid
                            MinWidth="520"
                            MinHeight="340"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Border
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="White"
                                BorderBrush="#E6ECF2"
                                BorderThickness="1">
                                <Border.LayoutTransform>
                                    <ScaleTransform
                                        ScaleX="{Binding PreviewZoom}"
                                        ScaleY="{Binding PreviewZoom}" />
                                </Border.LayoutTransform>
                                <local:BarcodeLabelPreview DataContext="{Binding}" />
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
