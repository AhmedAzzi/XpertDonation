<Window
    x:Class="XpertPharm5Donation.Views.BarcodeLabelDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:XpertPharm5Donation.Views"
    Title="Impression Code-Barres"
    Width="720"
    Height="440"
    Background="#F5F5F5"
    FontFamily="Segoe UI"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="OptionCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#333" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Background="White"
                                BorderBrush="#CCC"
                                BorderThickness="1"
                                CornerRadius="3">
                                <Border
                                    x:Name="CheckMark"
                                    Margin="3"
                                    Background="#2196F3"
                                    CornerRadius="2"
                                    Visibility="Collapsed">
                                    <Path
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M0,4 L3,7 L8,0"
                                        Stroke="White"
                                        StrokeThickness="2" />
                                </Border>
                            </Border>
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Text="{TemplateBinding Content}" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#2196F3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  LEFT PANEL - Options  -->
        <Border
            Grid.Column="0"
            Background="White"
            BorderBrush="#E0E0E0"
            BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Header  -->
                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,12"
                    FontSize="11"
                    FontWeight="Bold"
                    Foreground="#888"
                    Text="OPTIONS D'IMPRESSION" />

                <!--  Fields  -->
                <StackPanel Grid.Row="1">
                    <CheckBox
                        Content="Nom pharmacie"
                        IsChecked="{Binding ShowPharmacyName}"
                        Style="{StaticResource OptionCheckBox}" />
                    <Separator Margin="0,4" Opacity="0.3" />
                    <CheckBox
                        Content="Image code-barres"
                        IsChecked="{Binding ShowBarcodeImage}"
                        Style="{StaticResource OptionCheckBox}" />
                    <CheckBox
                        Content="N° code-barres"
                        IsChecked="{Binding ShowBarcodeNumber}"
                        Style="{StaticResource OptionCheckBox}" />
                    <Separator Margin="0,4" Opacity="0.3" />
                    <CheckBox
                        Content="Nom produit"
                        IsChecked="{Binding ShowProductName}"
                        Style="{StaticResource OptionCheckBox}" />
                    <CheckBox
                        Content="Prix"
                        IsChecked="{Binding ShowPrice}"
                        Style="{StaticResource OptionCheckBox}" />
                    <Separator Margin="0,4" Opacity="0.3" />
                    <CheckBox
                        Content="Date expiration"
                        IsChecked="{Binding ShowExpiry}"
                        Style="{StaticResource OptionCheckBox}" />
                    <CheckBox
                        Content="N° Lot"
                        IsChecked="{Binding ShowLot}"
                        Style="{StaticResource OptionCheckBox}" />
                </StackPanel>

                <!--  Buttons  -->
                <StackPanel
                    Grid.Row="2"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Background="#2196F3"
                        Command="{Binding PrintCommand}"
                        Content="Imprimer"
                        Foreground="White"
                        Style="{StaticResource ActionBtn}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button
                        Margin="0"
                        Background="#E0E0E0"
                        Command="{Binding CloseCommand}"
                        Content="Fermer"
                        Foreground="#555"
                        Style="{StaticResource ActionBtn}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  RIGHT PANEL - Preview  -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,12"
                FontSize="11"
                FontWeight="Bold"
                Foreground="#888"
                Text="APERÇU" />

            <!--  Preview Card  -->
            <Border
                Grid.Row="1"
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="12"
                        Direction="270"
                        Opacity="0.1"
                        ShadowDepth="4"
                        Color="#000" />
                </Border.Effect>
                <Grid>
                    <!--  Background pattern  -->
                    <Grid.Background>
                        <DrawingBrush
                            Opacity="0.03"
                            TileMode="Tile"
                            Viewport="0,0,20,20"
                            ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="#000">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,20,20" />
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Grid.Background>

                    <Viewbox Margin="20" Stretch="Uniform">
                        <local:BarcodeLabelPreview
                            Width="340"
                            Height="180"
                            DataContext="{Binding}" />
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
