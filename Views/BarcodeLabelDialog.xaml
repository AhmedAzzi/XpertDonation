<Window x:Class="XpertPharm5Donation.Views.BarcodeLabelDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:XpertPharm5Donation.Views"
    Title="Impression code-barres" Height="340" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <!-- Options -->
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Champs à imprimer :" FontWeight="Bold" Margin="0,0,0,8"/>
            <CheckBox Content="Nom de la pharmacie" IsChecked="{Binding ShowPharmacyName}"/>
            <CheckBox Content="Code-barres (image)" IsChecked="{Binding ShowBarcodeImage}"/>
            <CheckBox Content="Numéro code-barres" IsChecked="{Binding ShowBarcodeNumber}"/>
            <CheckBox Content="Nom du produit" IsChecked="{Binding ShowProductName}"/>
            <CheckBox Content="Prix" IsChecked="{Binding ShowPrice}"/>
            <CheckBox Content="Date de péremption" IsChecked="{Binding ShowExpiry}"/>
            <CheckBox Content="N° Lot" IsChecked="{Binding ShowLot}"/>
            <TextBlock Text="Taille police :" Margin="0,16,0,2"/>
            <Slider Minimum="7" Maximum="20" Value="{Binding FontSize}" TickFrequency="1" IsSnapToTickEnabled="True"/>
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Content="Imprimer" Width="80" Margin="0,0,8,0" Command="{Binding PrintCommand}"/>
                <Button Content="Fermer" Width="80" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </StackPanel>
        <!-- Preview -->
        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="6" Background="#FFF">
            <Viewbox Stretch="Uniform">
                <local:BarcodeLabelPreview DataContext="{Binding}" Width="200" Height="100"/>
            </Viewbox>
        </Border>
    </Grid>
</Window>
