<Window x:Class="XpertPharm5Donation.Views.DrugEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="460" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E2E8F0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.15" ShadowDepth="2" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="12,12,0,0" Padding="20,16">
                <Grid>
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="18" FontFamily="Segoe UI Semibold" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Content="✕" Click="Close_Click" 
                            Background="Transparent" BorderThickness="0" Foreground="White" FontSize="16"
                            Cursor="Hand" ToolTip="Fermer"/>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="30,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Désignation *" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                <TextBox Grid.Row="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBoxStyle}" Margin="0,0,0,16"/>

                <TextBlock Grid.Row="2" Text="DCI (Dénomination Commune Internationale)" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                <TextBox Grid.Row="3" Text="{Binding Dci, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBoxStyle}" Margin="0,0,0,16"/>

                <TextBlock Grid.Row="4" Text="Forme (ex: Gélule, Sirop...)" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                <TextBox Grid.Row="5" Text="{Binding Form, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBoxStyle}" Margin="0,0,0,16"/>

                <TextBlock Grid.Row="6" Text="Code-barres (optionnel)" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                <TextBox Grid.Row="7" Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBoxStyle}" Margin="0,0,0,16"/>

                <!-- Status Message -->
                <TextBlock Grid.Row="8" Text="{Binding StatusMessage}" 
                           Visibility="{Binding IsStatusError, Converter={StaticResource BoolVis}}"
                           Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="0,8,0,0"/>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,12,12" Padding="20,16" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Annuler" Command="{Binding CancelCommand}" 
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource GhostButtonStyle}" Width="100" Margin="0,0,12,0"/>
                    <Button Content="Enregistrer" Command="{Binding SaveCommand}" 
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource PrimaryButtonStyle}" MinWidth="130"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
