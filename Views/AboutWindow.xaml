<Window
    x:Class="XDonation.Views.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="À propos de XDonation"
    Width="500"
    Height="560"
    MinWidth="400"
    MinHeight="450"
    Style="{StaticResource ModernDialogStyle}"
    WindowStartupLocation="CenterOwner">

    <Border
        Margin="12"
        Background="White"
        CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="25"
                Opacity="0.2"
                ShadowDepth="4"
                Color="Black" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <Border Grid.Row="0" Style="{StaticResource DialogHeaderStyle}">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Foreground="White"
                            Text="ℹ️" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI Semibold"
                            FontSize="18"
                            Foreground="White"
                            Text="À propos de XDonation" />
                    </StackPanel>
                    <Button
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"
                        Style="{StaticResource CloseButtonStyle}"
                        ToolTip="Fermer" />
                </Grid>
            </Border>

            <!--  Content  -->
            <Grid Grid.Row="1" Margin="30,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Logo & App Info  -->
                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,25"
                    HorizontalAlignment="Center">
                    <Border
                        Width="84"
                        Height="84"
                        Margin="0,0,0,15"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="20">
                        <Image
                            Width="56"
                            Height="56"
                            Source="/Resources/xdonation.ico" />
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="Segoe UI Semibold"
                        FontSize="32"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="XDonation" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="Segoe UI"
                        FontSize="14"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Gestion des Médicaments Donnés" />
                    <Border
                        Margin="0,12,0,0"
                        Padding="12,4"
                        HorizontalAlignment="Center"
                        Background="{StaticResource SelectionBrush}"
                        CornerRadius="6">
                        <TextBlock
                            FontFamily="Segoe UI Semibold"
                            FontSize="12"
                            Foreground="{StaticResource AccentBrush}"
                            Text="Version 1.0.0" />
                    </Border>
                </StackPanel>

                <!--  Developer Card  -->
                <Border
                    Grid.Row="1"
                    Padding="25,20"
                    Background="#F8FAFC"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            Margin="0,0,0,16"
                            FontFamily="Segoe UI Bold"
                            FontSize="14"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="INFORMATIONS DÉVELOPPEUR" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Auteur:" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="Segoe UI Semibold"
                                FontSize="13"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Ahmed Azzi" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Email:" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="Segoe UI Semibold"
                                FontSize="13"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="mrahmedazzi@gmail.com" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Contact:" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="Segoe UI Semibold"
                                FontSize="13"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="0798756324" />
                        </Grid>

                        <Separator Margin="0,10" Opacity="0.3" />

                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="© 2026 Ahmed Azzi. Tous droits réservés." />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Footer  -->
            <Border
                Grid.Row="2"
                Padding="20,16"
                Background="#F8FAFC"
                BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12">
                <Button
                    Width="140"
                    Height="38"
                    HorizontalAlignment="Center"
                    Click="CloseButton_Click"
                    Content="Fermer"
                    Style="{StaticResource PrimaryButtonStyle}" />
            </Border>
        </Grid>
    </Border>
</Window>
