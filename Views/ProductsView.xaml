<UserControl x:Class="XpertPharm5Donation.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:XpertPharm5Donation.Converters"
             Background="{StaticResource WorkspaceBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToTextConverter x:Key="BoolText"/>
        <conv:StockColorConverter x:Key="StockColor"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ TOP FILTER & ACTION BAR ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search & Refresh -->
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="SearchBox" MinWidth="300" MinHeight="34" Margin="0,0,10,0"
                              Padding="8,2"
                              Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              KeyDown="SearchBox_KeyDown"
                              ToolTip="Tapez le nom ou le code-barres pour filtrer automatiquement"/>

                    <Button Command="{Binding LoadCommand}" MinWidth="120" MinHeight="32"
                            Style="{StaticResource GhostButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="⟳" FontSize="16" FontWeight="Bold" Margin="0,-2,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Actualiser" FontSize="12" VerticalAlignment="Center" Foreground="#333"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- CRUD Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding ShowEditDrugFormCommand}" MinWidth="110" MinHeight="32" Margin="0,0,10,0"
                            Style="{StaticResource GhostButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="✏" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#333"/>
                            <TextBlock Text="Modifier" FontSize="12" VerticalAlignment="Center" Foreground="#333"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding DeleteDrugCommand}" MinWidth="110" MinHeight="32" Margin="0,0,10,0"
                            Style="{StaticResource DangerButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🗑" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Supprimer" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowAddDrugFormCommand}" MinWidth="150" MinHeight="32"
                            Style="{StaticResource PrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="➕" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Nouveau produit" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ DATA GRID AREA ════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="34"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- DataGrid Header Title -->
                <Border Style="{StaticResource SectionHeaderBorderStyle}">
                    <TextBlock Text="Catalogue des produits donnés" Foreground="White" FontFamily="Segoe UI Semibold" VerticalAlignment="Center" FontSize="12.5"/>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Drugs}" SelectedItem="{Binding SelectedDrug}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          HeadersVisibility="Column" SelectionMode="Single"
                          MinRowHeight="32" BorderThickness="0" Background="Transparent"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produit" Binding="{Binding Name}" Width="2*"/>
                        <DataGridTextColumn Header="DCI" Binding="{Binding Dci}" Width="1.5*"/>
                        <DataGridTextColumn Header="Forme" Binding="{Binding Form}" Width="1*"/>
                        <DataGridTextColumn Header="Nb Lots" Binding="{Binding StockBatches.Count}" Width="0.6*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Stock valide" Binding="{Binding TotalValidStock}" Width="0.8*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Stock total" Binding="{Binding TotalAvailableStock}" Width="0.8*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ═══ STATUS / ERROR BAR ════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="0,12,0,0" Padding="12,6" CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#F0FDF4"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                            <Setter Property="Background" Value="#FEF2F2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}" FontFamily="Segoe UI" FontSize="12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#15803D"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                <Setter Property="Foreground" Value="#DC2626"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
