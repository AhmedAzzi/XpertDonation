<UserControl
    x:Class="XpertPharm5Donation.Views.BarcodeLabelPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="100"
    d:DesignWidth="200"
    mc:Ignorable="d">
    <Border
        Width="200"
        Height="100"
        Padding="2,2,0,2"
        BorderBrush="Black"
        BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Left column: all label content stacked vertically  -->
            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Stretch"
                Orientation="Vertical">

                <!--  Pharmacy Name  -->
                <TextBlock
                    Margin="0,0,0,1"
                    HorizontalAlignment="Center"
                    FontSize="8"
                    FontWeight="Bold"
                    Text="{Binding PharmacyName}"
                    Visibility="{Binding ShowPharmacyName, Converter={StaticResource BoolToVisConverter}}" />

                <!--  Barcode Image  -->
                <Image
                    Width="129"
                    Height="18"
                    Margin="0,2,0,0"
                    HorizontalAlignment="Center"
                    Source="{Binding BarcodeImage}"
                    Stretch="Fill"
                    Visibility="{Binding ShowBarcodeImage, Converter={StaticResource BoolToVisConverter}}" />

                <!--  Barcode Number  -->
                <TextBlock
                    Margin="0,0,0,0"
                    HorizontalAlignment="Center"
                    FontSize="17"
                    FontWeight="Bold"
                    LineHeight="18"
                    Text="{Binding BarcodeNumber}"
                    Visibility="{Binding ShowBarcodeNumber, Converter={StaticResource BoolToVisConverter}}" />

                <!--  Product Name  -->
                <TextBlock
                    Margin="2,0,2,0"
                    HorizontalAlignment="Left"
                    FontSize="9"
                    Text="{Binding ProductName}"
                    TextTrimming="CharacterEllipsis"
                    Visibility="{Binding ShowProductName, Converter={StaticResource BoolToVisConverter}}" />

                <!--  Price  -->
                <TextBlock
                    Margin="0,2,0,0"
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="{Binding Price}"
                    Visibility="{Binding ShowPrice, Converter={StaticResource BoolToVisConverter}}" />

            </StackPanel>

            <!--  Right column: vertical Expiry + Lot (rotated)  -->
            <StackPanel
                Grid.Column="1"
                Margin="2,0,2,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding ShowMeta, Converter={StaticResource BoolToVisConverter}}">

                <StackPanel.LayoutTransform>
                    <RotateTransform Angle="-90" />
                </StackPanel.LayoutTransform>

                <!--  LOT  -->
                <TextBlock
                    FontFamily="Segoe UI"
                    FontSize="9"
                    FontWeight="SemiBold"
                    Text="{Binding LotNumber, StringFormat=Lot: {0}}"
                    TextAlignment="Left" />

                <!--  EXP  -->
                <TextBlock
                    Margin="0,2,0,0"
                    FontFamily="Segoe UI"
                    FontSize="9"
                    FontWeight="SemiBold"
                    Text="{Binding ExpiryDate, StringFormat=Exp: {0:dd-MM-yyyy}}"
                    TextAlignment="Left" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
