<UserControl
    x:Class="XpertPharm5Donation.Views.BarcodeLabelPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="180"
    d:DesignWidth="340"
    mc:Ignorable="d">
    <Border
        Background="White"
        BorderBrush="#333"
        BorderThickness="1.5"
        CornerRadius="2">
        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: main content -->
            <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                <!-- Pharmacy -->
                <TextBlock Margin="0,0,0,3" HorizontalAlignment="Center"
                           FontSize="10" FontWeight="Bold" Foreground="#444"
                           Text="{Binding PharmacyName}"
                           Visibility="{Binding ShowPharmacyName, Converter={StaticResource BoolToVisConverter}}" />

                <!-- Barcode image -->
                <Image Width="220" Height="65" Margin="0,4" HorizontalAlignment="Center"
                       Stretch="Uniform"
                       Source="{Binding BarcodeImage}"
                       Visibility="{Binding ShowBarcodeImage, Converter={StaticResource BoolToVisConverter}}" />

                <!-- Barcode number -->
                <TextBlock Margin="0,2,0,4" HorizontalAlignment="Center"
                           FontSize="14" FontWeight="Bold" FontFamily="Consolas, Courier New"
                           Text="{Binding BarcodeNumber}"
                           Visibility="{Binding ShowBarcodeNumber, Converter={StaticResource BoolToVisConverter}}" />

                <!-- Product name -->
                <TextBlock Margin="4,0,4,2" HorizontalAlignment="Center"
                           FontSize="12" FontWeight="SemiBold" Foreground="#222"
                           Text="{Binding ProductName}"
                           TextTrimming="CharacterEllipsis"
                           Visibility="{Binding ShowProductName, Converter={StaticResource BoolToVisConverter}}" />

                <!-- Price -->
                <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center"
                           FontSize="22" FontWeight="Bold" Foreground="#1B5E20"
                           Text="{Binding Price}"
                           Visibility="{Binding ShowPrice, Converter={StaticResource BoolToVisConverter}}" />
            </StackPanel>

            <!-- Right: vertical meta info -->
            <StackPanel Grid.Column="1" Margin="6,0,0,0"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Orientation="Vertical">

                <!-- Expiry block -->
                <Border Margin="0,0,0,8" Padding="4,6" CornerRadius="3"
                        Background="#FFF3E0"
                        Visibility="{Binding ShowExpiry, Converter={StaticResource BoolToVisConverter}}">
                    <Border.LayoutTransform>
                        <RotateTransform Angle="-90"/>
                    </Border.LayoutTransform>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontSize="9" FontWeight="Bold" Foreground="#E65100" Text="EXP" TextAlignment="Center"/>
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#333"
                                   Text="{Binding ExpiryDate}" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Lot block -->
                <Border Padding="4,6" CornerRadius="3"
                        Background="#E3F2FD"
                        Visibility="{Binding ShowLot, Converter={StaticResource BoolToVisConverter}}">
                    <Border.LayoutTransform>
                        <RotateTransform Angle="-90"/>
                    </Border.LayoutTransform>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontSize="9" FontWeight="Bold" Foreground="#1565C0" Text="LOT" TextAlignment="Center"/>
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#333"
                                   Text="{Binding LotNumber}" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
