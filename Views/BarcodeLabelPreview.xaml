<UserControl
    x:Class="XDonation.Views.BarcodeLabelPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="200"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <Grid
        Width="400"
        Height="200"
        Background="White"
        ClipToBounds="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="82" />
        </Grid.ColumnDefinitions>

        <!--  Left column: label content stacked like the printed sticker  -->
        <Grid
            Grid.Column="0"
            Margin="6,4,0,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="45" />
                <RowDefinition Height="42" />
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="24"
                FontWeight="Bold"
                Text="{Binding PharmacyName}"
                Visibility="{Binding ShowPharmacyName, Converter={StaticResource BoolToVisConverter}}" />

            <Image
                Grid.Row="1"
                Width="230"
                Height="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Source="{Binding BarcodeImage}"
                Stretch="Fill"
                Visibility="{Binding ShowBarcodeImage, Converter={StaticResource BoolToVisConverter}}" />

            <TextBlock
                Grid.Row="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="42"
                FontWeight="Bold"
                LineHeight="42"
                Text="{Binding BarcodeNumber}"
                Visibility="{Binding ShowBarcodeNumber, Converter={StaticResource BoolToVisConverter}}" />

            <TextBlock
                Grid.Row="3"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="25"
                Text="{Binding ProductName}"
                TextTrimming="CharacterEllipsis"
                Visibility="{Binding ShowProductName, Converter={StaticResource BoolToVisConverter}}" />

            <TextBlock
                Grid.Row="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="48"
                FontWeight="Bold"
                Text="{Binding Price}"
                Visibility="{Binding ShowPrice, Converter={StaticResource BoolToVisConverter}}" />

        </Grid>

        <!--  Right column: vertical expiry and lot, matching the reference label  -->
        <Grid
            Grid.Column="1"
            Margin="0,0,4,0"
            Visibility="{Binding ShowMeta, Converter={StaticResource BoolToVisConverter}}">
            <TextBlock
                Margin="0,0,34,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe UI"
                FontSize="20"
                FontWeight="Bold"
                Text="{Binding ExpiryDate, StringFormat=Exp : {0}}"
                Visibility="{Binding ShowExpiry, Converter={StaticResource BoolToVisConverter}}">
                <TextBlock.LayoutTransform>
                    <RotateTransform Angle="-90" />
                </TextBlock.LayoutTransform>
            </TextBlock>

            <TextBlock
                Margin="45,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe UI"
                FontSize="20"
                FontWeight="Bold"
                Text="{Binding LotNumber, StringFormat=Lot : {0}}"
                Visibility="{Binding ShowLot, Converter={StaticResource BoolToVisConverter}}">
                <TextBlock.LayoutTransform>
                    <RotateTransform Angle="-90" />
                </TextBlock.LayoutTransform>
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>
