<Window x:Class="XpertPharm5Donation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:XpertPharm5Donation.Views"
        Title="XpertPharm5 Donation" Height="720" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WorkspaceBrush}">

    <Window.InputBindings>
        <KeyBinding Key="F8" Command="{Binding PosVM.ValidateCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding PosVM.CancelCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>   <!-- Header -->
            <RowDefinition Height="38"/>   <!-- Nav tabs -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="26"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="6" Background="#1D6CB5" Margin="0,0,10,0">
                        <TextBlock Text="💊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="XpertPharm5 Donation" FontFamily="Segoe UI Semibold" FontSize="16"
                                   Foreground="White"/>
                        <TextBlock Text="Gestion des Médicaments Donnés  |  v1.0.0" FontFamily="Segoe UI"
                                   FontSize="10.5" Foreground="#7090B0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Page label -->
                <TextBlock Grid.Column="1" x:Name="PageTitle" Text="Page d'accueil"
                           FontFamily="Segoe UI Light" FontSize="18" Foreground="#A0BFD8"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Clock -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="ClockText" FontFamily="Segoe UI Semibold" FontSize="18"
                               Foreground="White" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="DateText" FontFamily="Segoe UI" FontSize="10.5"
                               Foreground="#7090B0" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ NAV TABS ════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#0D2845">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <Button x:Name="BtnHome" Content="🏠  Page d'accueil"
                        Style="{StaticResource NavTabActiveStyle}"
                        Click="BtnHome_Click"/>
                <Button x:Name="BtnComptoir" Content="💊  Comptoir Don"
                        Style="{StaticResource NavTabStyle}"
                        Click="BtnComptoir_Click"/>
                <Button x:Name="BtnStock" Content="📦  Stock"
                        Style="{StaticResource NavTabStyle}"
                        Click="BtnStock_Click"/>
                <Button x:Name="BtnProducts" Content="🗃️  Produits"
                        Style="{StaticResource NavTabStyle}"
                        Click="BtnProducts_Click"/>
                <Button x:Name="BtnVouchers" Content="📄  Bons de don"
                        Style="{StaticResource NavTabStyle}"
                        Click="BtnVouchers_Click"/>
                <Button x:Name="BtnJournal" Content="📋  Journal des bons de don"
                        Style="{StaticResource NavTabStyle}"
                        Click="BtnJournal_Click"/>
                <Button x:Name="BtnHistory" Content="🔄  Historique Disp."
                        Style="{StaticResource NavTabStyle}"
                        Click="BtnHistory_Click"/>
            </StackPanel>
        </Border>

        <!-- ═══ CONTENT FRAME ═══════════════════════════════════════════════ -->
        <ContentControl Grid.Row="2" x:Name="MainContent"/>

        <!-- ═══ STATUS BAR ═══════════════════════════════════════════════════ -->
        <StatusBar Grid.Row="3" Style="{StaticResource StatusBarStyle}">
            <StatusBarItem>
                <TextBlock x:Name="DbStatus" Text="Base de données : XpertPharm5Donation" Foreground="#A0BFDF"/>
            </StatusBarItem>
            <Separator Background="#2A4A7A" Width="1" Margin="8,4"/>
            <StatusBarItem>
                <TextBlock Text="Utilisateur : Pharmacien" Foreground="#A0BFDF"/>
            </StatusBarItem>
            <Separator Background="#2A4A7A" Width="1" Margin="8,4"/>
            <StatusBarItem>
                <TextBlock Text="Version : 1.0.0" Foreground="#A0BFDF"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
