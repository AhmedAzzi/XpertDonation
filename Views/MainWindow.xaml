<Window
    x:Class="XpertPharm5Donation.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:XpertPharm5Donation.Views"
    Title="XpertPharm5 Donation"
    Width="1280"
    Height="720"
    MinWidth="800"
    MinHeight="500"
    Background="{StaticResource WorkspaceBrush}"
    WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding NavHomeCommand}" />
        <KeyBinding Key="F2" Command="{Binding NavComptoirCommand}" />
        <KeyBinding Key="F3" Command="{Binding NavStockCommand}" />
        <KeyBinding Key="F4" Command="{Binding NavProductsCommand}" />
        <KeyBinding Key="F5" Command="{Binding NavVouchersCommand}" />
        <KeyBinding Key="F6" Command="{Binding NavJournalCommand}" />
        <KeyBinding Key="F7" Command="{Binding NavHistoryCommand}" />
        <KeyBinding Key="F8" Command="{Binding PosVM.ValidateCommand}" />
        <KeyBinding Key="Escape" Command="{Binding PosVM.CancelCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="56" />
            <!--  Header  -->
            <RowDefinition Height="Auto" MinHeight="32" />
            <!--  Nav tabs  -->
            <RowDefinition Height="*" />
            <!--  Content  -->
            <RowDefinition Height="Auto" MinHeight="24" />
            <!--  Status bar  -->
        </Grid.RowDefinitions>

        <!--  ═══ HEADER ══════════════════════════════════════════════════════  -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}">
            <Grid Margin="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Logo + Title  -->
                <StackPanel
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Border
                        Width="36"
                        Height="36"
                        Margin="0,0,10,0"
                        Background="#1D6CB5"
                        CornerRadius="8">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Text="💊" />
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontFamily="Segoe UI Semibold"
                            FontSize="17"
                            Foreground="White"
                            Text="XpertPharm5 Donation" />
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="11"
                            Foreground="#7090B0"
                            Text="Gestion des Médicaments Donnés  |  v1.0.0" />
                    </StackPanel>
                </StackPanel>

                <!--  Page label  -->
                <TextBlock
                    x:Name="PageTitle"
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="Segoe UI Light"
                    FontSize="18"
                    Foreground="#A0BFD8"
                    Text="Page d'accueil" />

                <!--  Clock  -->
                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="ClockText"
                        HorizontalAlignment="Right"
                        FontFamily="Segoe UI Semibold"
                        FontSize="18"
                        Foreground="White" />
                    <TextBlock
                        x:Name="DateText"
                        HorizontalAlignment="Right"
                        FontFamily="Segoe UI"
                        FontSize="11"
                        Foreground="#7090B0" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  ═══ NAV TABS ════════════════════════════════════════════════════  -->
        <Border Grid.Row="1" Background="{StaticResource PrimaryDarkBrush}">
            <ScrollViewer
                Height="Auto"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Disabled">
                <StackPanel
                    Margin="6,2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        x:Name="BtnHome"
                        Click="BtnHome_Click"
                        Content="🏠  Accueil  (F1)"
                        Style="{StaticResource NavTabActiveStyle}" />
                    <Button
                        x:Name="BtnComptoir"
                        Click="BtnComptoir_Click"
                        Content="💊  Comptoir  (F2)"
                        Style="{StaticResource NavTabStyle}" />
                    <Button
                        x:Name="BtnStock"
                        Click="BtnStock_Click"
                        Content="📦  Stock  (F3)"
                        Style="{StaticResource NavTabStyle}" />
                    <Button
                        x:Name="BtnProducts"
                        Click="BtnProducts_Click"
                        Content="🗃️  Produits  (F4)"
                        Style="{StaticResource NavTabStyle}" />
                    <Button
                        x:Name="BtnVouchers"
                        Click="BtnVouchers_Click"
                        Content="📄  Bons de don  (F5)"
                        Style="{StaticResource NavTabStyle}" />
                    <Button
                        x:Name="BtnJournal"
                        Click="BtnJournal_Click"
                        Content="📋  Journal  (F6)"
                        Style="{StaticResource NavTabStyle}" />
                    <Button
                        x:Name="BtnHistory"
                        Click="BtnHistory_Click"
                        Content="📊  Historique  (F7)"
                        Style="{StaticResource NavTabStyle}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!--  ═══ CONTENT FRAME ═══════════════════════════════════════════════  -->
        <ContentControl x:Name="MainContent" Grid.Row="2" />

        <!--  ═══ STATUS BAR ═══════════════════════════════════════════════════  -->
        <StatusBar Grid.Row="3" Style="{StaticResource StatusBarStyle}">
            <StatusBarItem>
                <TextBlock
                    x:Name="DbStatus"
                    Foreground="#A0BFDF"
                    Text="Base de données : XpertPharm5Donation" />
            </StatusBarItem>
            <Separator
                Width="1"
                Margin="8,4"
                Background="#2A4A7A" />
            <StatusBarItem>
                <TextBlock Foreground="#A0BFDF" Text="Utilisateur : Pharmacien" />
            </StatusBarItem>
            <Separator
                Width="1"
                Margin="8,4"
                Background="#2A4A7A" />
            <StatusBarItem>
                <TextBlock Foreground="#A0BFDF" Text="Version : 1.0.0" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
